    "type-check": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5.7",
    "vitest": "^3.0",
    "yaml": "^2.8.2"
  }
}
